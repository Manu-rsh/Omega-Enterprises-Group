Download Product Images from any website:

> $baseUrl = URL/website from where we want to fetch the images --> "https://belvish.com/"
> outputFolder = Where the images will be saved in out system --> "C:\Omega Enterprises\Omega Perfumes\All images"
> Go to PowerShell
> Run below command


$baseUrl = "https://belvish.com/"
$outputFolder = "C:\Omega Enterprises\Omega Perfumes\All images"

New-Item -ItemType Directory -Force -Path $outputFolder

$page = 1

function Clean-FileName($name) {
    return ($name -replace '[\\/:*?"<>|]', '').Trim()
}

while ($true) {
    $url = "$baseUrl/products.json?limit=250&page=$page"
    Write-Host "Fetching page $page..."

    try {
        $response = Invoke-RestMethod -Uri $url -Method Get
    } catch {
        break
    }

    if ($response.products.Count -eq 0) {
        break
    }

    foreach ($product in $response.products) {
        $productName = Clean-FileName($product.title)
        $index = 1

        foreach ($image in $product.images) {
            $imgUrl = $image.src.Split("?")[0]

            # Get extension
            $ext = [System.IO.Path]::GetExtension($imgUrl)

            # Create new filename
            $fileName = "$productName" + "_$index" + "$ext"
            $filePath = Join-Path $outputFolder $fileName

            if (!(Test-Path $filePath)) {
                Write-Host "Downloading $fileName"
                Invoke-WebRequest $imgUrl -OutFile $filePath
            }

            $index++
        }
    }

    $page++
}

Write-Host "All images downloaded with product names ✅"
